{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "citycommute-client",
  "compatibility_date": "2026-04-30",
  "observability": {
    "enabled": true
  },
  "main": "src/worker.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
